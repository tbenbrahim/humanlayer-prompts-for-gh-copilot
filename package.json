{
  "name": "humanlayer-extension",
  "displayName": "Humanlayer Copilot Bundle",
  "description": "Install humanlayer-derived GitHub Copilot prompts and companion agents into a workspace.",
  "version": "2026.4.5",
  "publisher": "tony-benbrahim",
  "author": {
    "name": "Tony BenBrahim",
    "email": "tony.benbrahim+github@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tbenbrahim/humanlayer-prompts-for-gh-copilot.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "humanlayer",
    "copilot",
    "github-copilot",
    "skills",
    "prompts",
    "agents",
    "customization",
    "developer-workflows"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "humanlayer.installWorkspaceBundle",
        "title": "Install humanlayer Copilot Bundle",
        "category": "Chat"
      },
      {
        "command": "humanlayer.uninstallWorkspaceBundle",
        "title": "Uninstall humanlayer Copilot Bundle",
        "category": "Chat"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.3"
  }
}